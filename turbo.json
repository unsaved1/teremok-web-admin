{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "outputs": ["dist/**", "build/**"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "localPreview": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": ["PORT", "NODE_ENV"]
    }
  }
}
